[alias]
  tree = log --graph --date=format-local:'%Y/%m/%d %H:%M:%S' --pretty=format:'%x09%C(auto) %h %Cgreen %ad %Creset%x09by"%C(cyan ul)%an%Creset" %x09%C(auto)%s %d'

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections

    # delta detects terminal colors automatically; set one of these to disable auto-detection
    dark = true
    # light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
[core]
    editor= nvim

