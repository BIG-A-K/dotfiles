# Shared aliases for bash and zsh. Optional tools are enabled only when present.

alias rm='rm -i'
alias cp='cp -i'
alias cls='clear'
alias history='history 1'

alias la='ls -A'
alias ll='ls -la'
alias sl='ls'

alias en='export LANG=en_US.UTF-8; echo LANG=en_US.UTF-8'
alias jp='export LANG=ja_JP.UTF-8; echo LANG=ja_JP.UTF-8'
alias ja='export LANG=ja_JP.UTF-8; echo LANG=ja_JP.UTF-8'

if command -v bat >/dev/null 2>&1; then
  alias cat='bat --plain'
  alias le='bat --plain'
fi

if command -v eza >/dev/null 2>&1; then
  alias tree='eza -T --icons'
  alias l='eza --icons --color=always --group-directories-first --long --header'
fi

if command -v git >/dev/null 2>&1; then
  alias gt='git tree'
  alias gl='git log'
  alias gb='git branch'
  alias gs='git status'
  alias gd='git diff'
fi

if command -v opencode >/dev/null 2>&1; then
  alias oc='opencode'
fi

if command -v tmux >/dev/null 2>&1; then
  alias tmuxa='tmux a'
  alias t='tmux new-session -s "${PWD##*/}"'
fi

if command -v rsync >/dev/null 2>&1; then
  alias rsync='rsync -vzr'
fi

if command -v last >/dev/null 2>&1 && command -v less >/dev/null 2>&1; then
  alias last='last | less'
fi

if [ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]; then
  alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'
fi

case "${TERM_PROGRAM:-}" in
  WezTerm)
    if command -v wezterm >/dev/null 2>&1; then
      alias imgcat='wezterm imgcat'
    fi
    ;;
esac
